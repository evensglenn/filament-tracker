rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: filaments
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required, immutable) - Owner's UID
    //   - brand: string (required)
    //   - type: string (required)
    //   - colorName: string (required)
    //   - colorHex: string (required)
    //   - quantity: number (required)
    //   - notes: string (optional)
    //   - lastUsed: string (optional, ISO 8601)
    //   - createdAt: string (optional, ISO 8601)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidFilament(data) {
      return hasRequiredFields(['uid', 'brand', 'type', 'colorName', 'colorHex', 'quantity']) &&
             hasOnlyAllowedFields(['uid', 'brand', 'type', 'colorName', 'colorHex', 'quantity', 'notes', 'lastUsed', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.brand is string && data.brand.size() > 0 && data.brand.size() < 100 &&
             data.type is string && data.type.size() > 0 && data.type.size() < 50 &&
             data.colorName is string && data.colorName.size() > 0 && data.colorName.size() < 100 &&
             data.colorHex is string && data.colorHex.matches('^#[0-9A-Fa-f]{6}$') &&
             data.quantity is number && data.quantity >= 0 && data.quantity < 1000 &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 1000)) &&
             (!('lastUsed' in data) || data.lastUsed is string) &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    match /filaments/{filamentId} {
      // Users can only read their own filaments
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      
      // Users can only create filaments for themselves
      allow create: if isAuthenticated() && 
                      isValidFilament(request.resource.data) && 
                      request.resource.data.uid == request.auth.uid;
      
      // Users can only update their own filaments
      allow update: if isAuthenticated() && 
                      isDocOwner() && 
                      isValidFilament(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid;
      
      // Users can only delete their own filaments
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
